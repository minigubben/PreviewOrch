{
  "name": "pr-preview-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Small Docker-based PR preview orchestrator for GitHub pull requests.",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node dist/src/server.js",
    "build:node": "rm -rf dist && tsc -p tsconfig.node.json && mkdir -p dist/src && cp -R src/views dist/src/views",
    "build:client": "vite build",
    "build": "npm run build:node && npm run build:client",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "npm run build:node && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "supertest": "^7.1.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  }
}
