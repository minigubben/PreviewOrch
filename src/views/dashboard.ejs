<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PR Preview Orchestrator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      window.CSRF_TOKEN = "<%= csrfToken %>";
    </script>
    <script src="/static/app.js?v=<%= assetVersion %>" defer></script>
  </head>
  <body class="min-h-screen bg-black text-zinc-100 antialiased">
    <main class="min-h-screen">
      <section class="border-b border-zinc-800">
        <div class="mx-auto flex max-w-[1800px] items-start justify-between gap-6 px-5 py-5">
          <div>
            <p class="text-xs uppercase tracking-[0.34em] text-zinc-500">Control</p>
            <h1 class="mt-2 text-4xl font-semibold text-zinc-50">minigubben</h1>
            <p class="mt-3 max-w-xl text-sm leading-6 text-zinc-400">
              Preview hosts land at
              <code class="text-zinc-300">{repoSlug}-{deploymentKey}.<%= baseDomain %></code>
              for PR and branch targets.
            </p>
          </div>
          <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="border border-zinc-800 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800">
              Sign out
            </button>
          </form>
        </div>
        <div class="mx-auto max-w-[1800px] px-5 pb-4">
          <p class="text-sm text-zinc-300" data-ui-status></p>
        </div>
      </section>

      <%- include("partials/repo-config") %>

      <section class="border-t border-zinc-800">
        <div class="mx-auto max-w-[1800px] px-5 py-5">
          <div class="mb-6">
            <p class="text-xs uppercase tracking-[0.34em] text-zinc-500">Runtime</p>
            <h2 class="mt-3 text-4xl font-semibold text-zinc-50">Preview runtime details</h2>
            <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-400">
              Use repo-owned Traefik labels, or let the orchestrator append them. Deployment logs, compose contract details, and runtime history are shown below for webhook-driven PR previews and manual targets.
            </p>
          </div>

          <div class="grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
            <section class="space-y-6">
              <div class="border border-zinc-800 bg-zinc-950/70 px-5 py-5">
                <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">SSH Key</p>
                <p class="mb-4 text-sm leading-6 text-zinc-400">Generate or rotate the GitHub access key from the UI.</p>
                <button
                  type="button"
                  data-api-action
                  data-method="POST"
                  data-action="/api/ssh-keypair"
                  class="mb-4 border border-zinc-700 bg-zinc-900 px-4 py-3 text-left text-sm font-medium text-zinc-100 transition hover:bg-zinc-800"
                  <%= sshKeyStatus.hasKey ? 'data-confirm="An SSH key already exists. Generate a new keypair and replace the current one?"' : "" %>
                >
                  <%= sshKeyStatus.hasKey ? "Rotate SSH keypair" : "Generate SSH keypair" %>
                </button>
                <% if (sshKeyStatus.hasKey) { %>
                  <p class="mb-3 text-xs uppercase tracking-[0.28em] text-zinc-500">Active Key Type</p>
                  <p class="mb-4 text-sm text-zinc-300"><code><%= sshKeyStatus.algorithm %></code></p>
                  <pre class="overflow-x-auto border border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200"><%= sshKeyStatus.publicKey %></pre>
                <% } else { %>
                  <p class="text-sm leading-6 text-zinc-400">No SSH keypair exists yet. Generate one, then add the public key to GitHub deploy keys or your automation account.</p>
                <% } %>
              </div>

              <div class="border border-zinc-800 bg-zinc-950/70 px-5 py-5">
                <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">Compose Contract</p>
                <pre class="overflow-x-auto border border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200">services:
  app:
    networks:
      - default
      - preview-proxy
    labels:
      - traefik.enable=true
      - traefik.docker.network=<%= traefikNetworkName %>
      - traefik.http.routers.${ORCH_PROJECT_NAME}.rule=Host(`${ORCH_PREVIEW_HOST}`)
      - traefik.http.routers.${ORCH_PROJECT_NAME}.entrypoints=web
      - traefik.http.services.${ORCH_PROJECT_NAME}.loadbalancer.server.port=${ORCH_PREVIEW_SERVICE_PORT}

networks:
  preview-proxy:
    external: true
    name: <%= traefikNetworkName %></pre>
              </div>

              <div class="border border-zinc-800 bg-zinc-950/70 px-5 py-5">
                <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">App Log Tail</p>
                <p class="mb-4 text-sm leading-6 text-zinc-400">Append-only operator log from <code class="text-zinc-300">data/logs/app.log</code>.</p>
                <pre class="overflow-x-auto border border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200"><%= appLogTail || "No events logged yet." %></pre>
              </div>
            </section>

            <%- include("partials/deployments-panel") %>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
