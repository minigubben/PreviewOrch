<section class="border border-zinc-800 bg-zinc-950/70 px-5 py-5" data-deployments-root>
  <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">Deployments</p>
  <div class="space-y-5">
    <% if (!deployments.length) { %>
      <p class="text-sm text-zinc-500">No active or historical deployments yet.</p>
    <% } %>
    <% deployments.forEach((deployment) => { %>
      <details class="border border-zinc-800 bg-black/70" data-preserve-open="deployment:<%= deployment.deploymentId %>">
        <summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-3 border-b border-zinc-800 px-4 py-4">
          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-zinc-500">Deployment</p>
            <h3 class="mt-2 text-xl font-semibold text-zinc-50">
              <%= deployment.repoSlug %>
              <%= deployment.targetType === "branch" ? `Branch ${deployment.targetValue}` : `PR #${deployment.targetValue ?? deployment.prNumber}` %>
            </h3>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs uppercase tracking-[0.24em] text-zinc-500">Expand</span>
            <span class="border border-zinc-800 px-3 py-1 text-xs uppercase tracking-[0.24em] text-zinc-200"><%= deployment.status %></span>
          </div>
        </summary>
        <div class="space-y-4 px-4 py-4 text-sm text-zinc-400">
          <div>Host: <a href="http://<%= deployment.previewHost %>" target="_blank" rel="noreferrer" class="text-zinc-100 underline decoration-zinc-700 underline-offset-4"><%= deployment.previewHost %></a></div>
          <div>Project: <code class="text-zinc-200"><%= deployment.projectName %></code></div>
          <div>Last event: <code class="text-zinc-200"><%= deployment.lastEvent %></code></div>
          <div class="border border-zinc-800 bg-zinc-950/70 px-4 py-4">
            <p class="mb-3 text-xs uppercase tracking-[0.28em] text-zinc-500">Live Runtime</p>
            <% if (!deployment.runtime || deployment.runtime.available === false) { %>
              <p class="text-sm text-zinc-500">Docker inspection unavailable<% if (deployment.runtime?.reason) { %>: <code class="text-zinc-400"><%= deployment.runtime.reason %></code><% } %>.</p>
            <% } else if (!deployment.runtime.containers.length) { %>
              <p class="text-sm text-zinc-500">No live containers found for this Compose project.</p>
            <% } else { %>
              <% if (deployment.runtime.publicServiceContainer) { %>
                <div class="mb-4 space-y-2">
                  <div>Target container: <code class="text-zinc-200"><%= deployment.runtime.publicServiceContainer.name %></code></div>
                  <div>Service: <code class="text-zinc-200"><%= deployment.runtime.publicServiceContainer.service %></code></div>
                  <div>State: <code class="text-zinc-200"><%= deployment.runtime.publicServiceContainer.state %></code></div>
                  <div>Networks: <code class="text-zinc-200"><%= deployment.runtime.publicServiceContainer.networks.join(", ") || "none" %></code></div>
                </div>
                <details class="border border-zinc-800 bg-black/40" data-preserve-open="deployment:<%= deployment.deploymentId %>:target-labels">
                  <summary class="cursor-pointer list-none px-4 py-3 text-xs uppercase tracking-[0.28em] text-zinc-500">Target Labels</summary>
                  <pre class="overflow-x-auto border-t border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200"><%= JSON.stringify(deployment.runtime.publicServiceContainer.labels, null, 2) %></pre>
                </details>
                <details class="mt-4 border border-zinc-800 bg-black/40" data-preserve-open="deployment:<%= deployment.deploymentId %>:target-logs">
                  <summary class="cursor-pointer list-none px-4 py-3 text-xs uppercase tracking-[0.28em] text-zinc-500">Target Container Logs</summary>
                  <pre class="overflow-x-auto border-t border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200"><%= deployment.runtime.publicServiceContainer.logTail || "No container log output yet." %></pre>
                </details>
              <% } %>
              <div class="mt-4 space-y-3">
                <% deployment.runtime.containers.forEach((container) => { %>
                  <details class="border border-zinc-800 px-3 py-3" data-preserve-open="deployment:<%= deployment.deploymentId %>:container:<%= container.name %>">
                    <summary class="cursor-pointer list-none">
                      <div class="text-sm text-zinc-200"><code><%= container.name %></code></div>
                      <div class="mt-2 text-xs uppercase tracking-[0.22em] text-zinc-500"><%= container.service %> · <%= container.state %></div>
                      <div class="mt-2 text-xs text-zinc-400">Networks: <%= container.networks.join(", ") || "none" %></div>
                    </summary>
                    <pre class="mt-3 overflow-x-auto border border-zinc-800 bg-[#050505] px-3 py-3 text-xs leading-6 text-zinc-200"><%= container.logTail || "No container log output yet." %></pre>
                  </details>
                <% }) %>
              </div>
            <% } %>
          </div>
          <div class="flex flex-wrap gap-3">
            <button
              type="button"
              data-api-action
              data-method="POST"
              data-action="/api/deployments/<%= deployment.deploymentId %>/redeploy"
              class="border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm font-medium text-zinc-100 transition hover:bg-zinc-800"
            >
              Redeploy
            </button>
            <button
              type="button"
              data-api-action
              data-method="DELETE"
              data-action="/api/deployments/<%= deployment.deploymentId %>"
              class="border border-red-950 bg-red-950/20 px-4 py-2.5 text-sm font-medium text-red-100 transition hover:bg-red-900/40"
            >
              Destroy
            </button>
          </div>
          <details class="border border-zinc-800 bg-black/40" data-preserve-open="deployment:<%= deployment.deploymentId %>:script-log">
            <summary class="cursor-pointer list-none px-4 py-3 text-xs uppercase tracking-[0.28em] text-zinc-500">Orchestrator Script Log</summary>
            <pre class="overflow-x-auto border-t border-zinc-800 bg-[#050505] px-4 py-4 text-xs leading-6 text-zinc-200"><%= deployment.logTail || "No log output yet." %></pre>
          </details>
        </div>
      </details>
    <% }) %>
  </div>
</section>
