<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PR Preview Orchestrator</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="min-h-screen bg-black text-zinc-100 antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 py-10">
      <section class="grid w-full gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="hidden border-l border-zinc-800 pl-8 lg:block">
          <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">Preview Infrastructure</p>
          <h1 class="max-w-3xl text-5xl font-semibold leading-tight text-zinc-50">
            PR preview orchestration without hidden automation.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-400">
            GitHub webhook intake, explicit repo configuration, Docker Compose deploys, and proxy wiring that stays inspectable.
          </p>
        </div>
        <div class="border border-zinc-800 bg-zinc-950/80 px-6 py-8">
          <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">Admin Access</p>
          <h2 class="text-3xl font-semibold text-zinc-50">Sign in</h2>
          <p class="mt-3 max-w-md text-sm leading-6 text-zinc-400">
            Use the local admin account configured by environment variables.
          </p>
          <% if (error) { %>
            <p class="mt-6 border border-red-950 bg-red-950/30 px-4 py-3 text-sm text-red-200"><%= error %></p>
          <% } %>
          <form method="post" action="/login" class="mt-8 space-y-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="space-y-2">
              <label for="username" class="block text-xs uppercase tracking-[0.28em] text-zinc-500">Username</label>
              <input
                id="username"
                name="username"
                required
                class="w-full border border-zinc-800 bg-zinc-900 px-4 py-3 text-base text-zinc-100 outline-none transition focus:border-zinc-600"
              />
            </div>
            <div class="space-y-2">
              <label for="password" class="block text-xs uppercase tracking-[0.28em] text-zinc-500">Password</label>
              <input
                id="password"
                type="password"
                name="password"
                required
                class="w-full border border-zinc-800 bg-zinc-900 px-4 py-3 text-base text-zinc-100 outline-none transition focus:border-zinc-600"
              />
            </div>
            <button
              type="submit"
              class="inline-flex items-center justify-center border border-zinc-700 bg-zinc-100 px-5 py-3 text-sm font-medium text-black transition hover:bg-zinc-300"
            >
              Sign in
            </button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
